FROM ghcr.io/cross-rs/aarch64-unknown-linux-musl:main

ENV DEBIAN_FRONTEND=noninteractive

# salus links aws-lc-sys (via aws-lc-rs), whose build script compiles C with
# cmake. The cross base image already provides the aarch64 musl cross toolchain;
# we only add the build tooling aws-lc-sys needs (cmake + perl for its codegen,
# plus a C/C++ toolchain).
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        cmake perl pkg-config clang && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Point aws-lc-sys / cc-rs at the musl cross compiler so the static archive uses
# the MUSL ABI.
ENV CC_aarch64_unknown_linux_musl=aarch64-linux-musl-gcc \
    CXX_aarch64_unknown_linux_musl=aarch64-linux-musl-g++ \
    AR_aarch64_unknown_linux_musl=aarch64-linux-musl-ar
